# ---------------------------------------------------------------------------
# Copy to .env and edit to enable REAL mode. With NO .env file the project
# runs fully keyless (deterministic fakes, zero cost). Defaults below = fake.
# ---------------------------------------------------------------------------

# --- Provider selection: "fake" (default, keyless) or real ------------------
LLM_PROVIDER=fake            # fake | openai
SEARCH_PROVIDER=fake         # fake | web
FETCH_PROVIDER=fake          # fake | http

# --- OpenAI (only used when LLM_PROVIDER=openai) ----------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Real web search (only used when SEARCH_PROVIDER=web) -------------------
# NOTE: SEARCH_PROVIDER=web requires FETCH_PROVIDER=http (validated at startup),
# and only the tavily backend is implemented so far.
SEARCH_API_KEY=
SEARCH_BACKEND=tavily        # tavily (brave | serpapi: not implemented yet)

# --- Run knobs --------------------------------------------------------------
MAX_ITERATIONS=2
TOKEN_BUDGET=60000
REQUIRE_APPROVAL=false
TOP_SEARCH_RESULTS=5
# Report depth: sources (and claims) gathered per sub-question. Raise for more
# thorough reports; sources are fetched in parallel so deeper runs stay fast.
EVIDENCE_PER_SUBQUESTION=2
RESEARCH_CONCURRENCY=4        # parallel search/fetch workers (output is identical regardless)
ENABLE_CRITIC=true
ENABLE_CACHE=true
CACHE_SIZE=256
MAX_QUESTION_LENGTH=2000

# --- DSPy track (optional; reuses OPENAI_API_KEY above) ----------------------
AGENT_BACKEND=manual          # manual | dspy
DSPY_MODEL=openai/gpt-4o-mini
DSPY_OPTIMIZER=bootstrap      # bootstrap | mipro
# DSPY_ARTIFACT_PATH=artifacts/dspy_program.json

# --- Paths (sensible defaults; rarely need changing) ------------------------
# Point CORPUS_DIR at a folder of your OWN .md / .txt / .pdf files to research
# them instead of the bundled corpus (works keyless; PDF needs `pip install pypdfium2`).
# CORPUS_DIR=data/corpus
# TRACES_DIR=runs
# RESULTS_DIR=eval/results
